# Copy this file to `.env` and fill in your own Azure resource details.
# `.env` is gitignored and never committed.

# --- Azure OpenAI ---
# Endpoint of an Azure OpenAI resource that hosts the embedding + chat deployments.
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com
# Optional: key-based auth. If omitted, Azure AD (az login / DefaultAzureCredential) is used.
# AZURE_OPENAI_API_KEY=
EMBEDDING_DEPLOYMENT=text-embedding-3-small
CHAT_DEPLOYMENT=gpt-4.1-mini
EMBEDDING_API_VERSION=2024-10-21
RESPONSES_API_VERSION=2025-04-01-preview

# --- Azure Cosmos DB for NoSQL ---
# Account must have the EnableNoSQLVectorSearch + EnableNoSQLFullTextSearch capabilities.
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=contracts_demo
COSMOS_CONTAINER=agreements
# Optional: key-based auth. If omitted, Azure AD is used (needs Cosmos DB Built-in Data Contributor).
# COSMOS_KEY=
